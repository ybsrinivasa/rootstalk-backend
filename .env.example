# PostgreSQL
DATABASE_URL=postgresql+asyncpg://rootstalk:CHANGE_ME@localhost:5432/rootstalk_dev
DATABASE_URL_SYNC=postgresql://rootstalk:CHANGE_ME@localhost:5432/rootstalk_dev

# Redis
REDIS_URL=redis://localhost:6379/1
CELERY_BROKER_URL=redis://localhost:6379/1
CELERY_RESULT_BACKEND=redis://localhost:6379/1

# Security — generate with: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=CHANGE_ME_64_CHAR_RANDOM_HEX
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60
REFRESH_TOKEN_EXPIRE_DAYS=7

# Cosh sync
COSH_SYNC_API_KEY=CHANGE_ME

# AWS S3
AWS_ACCESS_KEY_ID=CHANGE_ME
AWS_SECRET_ACCESS_KEY=CHANGE_ME
AWS_S3_BUCKET_NAME=CHANGE_ME
AWS_S3_REGION=ap-south-1
AWS_CLOUDFRONT_URL=

# Google APIs
GOOGLE_TRANSLATE_API_KEY=CHANGE_ME
GOOGLE_VISION_API_KEY=CHANGE_ME

# RazorPay
RAZORPAY_KEY_ID=CHANGE_ME
RAZORPAY_KEY_SECRET=CHANGE_ME

# Firebase FCM
FCM_SERVER_KEY=CHANGE_ME

# Email (for portal user credentials)
EMAIL_SMTP_HOST=smtp.gmail.com
EMAIL_SMTP_PORT=587
EMAIL_SMTP_USER=CHANGE_ME
EMAIL_SMTP_PASS=CHANGE_ME
EMAIL_FROM=CHANGE_ME

# Super Admin
SA_EMAIL=CHANGE_ME
SA_PASSWORD=CHANGE_ME_STRONG_PASSWORD

# CORS
ALLOWED_ORIGINS=http://localhost:3000

# Environment
ENVIRONMENT=development
